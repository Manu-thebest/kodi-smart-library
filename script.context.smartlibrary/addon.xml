<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.context.smartlibrary" name="Smart Library" version="6.11.8" provider-name="Manu">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="context_menu.py">
                <label>Añadir a mi Librería Inteligente</label>
                <visible>true</visible>
            </item>
        </menu>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <news>6.11.5: Al iniciar Kodi, espera 30s y luego lanza UpdateLibrary(video) para que Kodi escanee los .strm automaticamente. 6.11.4: Eliminada inyección directa en BD.</news>
    </extension>
</addon>
